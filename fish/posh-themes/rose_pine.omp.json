{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
        "os": "#ea9d34",
        "closer": "p:os",
        "pink": "#ea9a97",
        "lavender": "#c4a7e7",
        "blue":  "#3e8fb0"
  },
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
            "foreground" : "#eb6f92",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "style": "diamond",
          "template": " {{ .UpstreamIcon }} <##eb6f92>Branch : </> {{ .HEAD  }} {{if .BranchStatus }} {{ .BranchStatus }}{{ end }} {{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#c4a7e7",
          "properties": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": "<#e0def4> \u007C </><#3e8fb0>\ue718</> {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "type": "node"
        },
        {
          "type": "php",
          "style": "powerline",
          "foreground": "#c4a7e7",
          "template": "<#e0def4> \u007C </><#3e8fb0>\ue73d</> {{ .Full }}"
        },
        {
          "type": "npm",
          "style": "powerline",
          "foreground": "#c4a7e7",
          "template": "<#e0def4> \u007C </><#3e8fb0>\ue71e </> {{ .Full }}"
        },
        {
          "type": "sysinfo",
          "style": "powerline",
          "foreground": "#3e8fb0",
          "template": "<> </>"
        },
        {
          "foreground": "#f6c177",
          "properties": {
            "style": "austin",
            "threshold": 150
          },
          "style": "diamond",
          "template": " <#ebbcba>| Execution Time: </> {{ .FormattedMs }} ",
          "type": "executiontime"
        }
        
      ],
      "type": "prompt"
    },
{
      "alignment": "left",
      "newline" : true,
      "segments": [
        {
          "foreground": "p:os",
          "style": "plain",
          "template": "{{.Icon}} ",
          "type": "os"
        },
        {
          "foreground": "p:blue",
          "style": "plain",
          "template": "{{ .UserName }} | {{ .HostName }} | ",
          "type": "session"
        },
        {
          "foreground": "p:pink",
          "properties": {
            "folder_icon": "..\ue5fe..",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "style": "plain",
          "foreground": "#9ccfd8",
          "template": ":",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}
